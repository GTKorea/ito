{
  "display_information": {
    "name": "ito",
    "description": "Thread-based collaborative task management",
    "background_color": "#0A0A0A"
  },
  "features": {
    "bot_user": {
      "display_name": "ito",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/ito",
        "url": "https://api.itothread.com/slack/commands",
        "description": "Manage tasks with ito",
        "usage_hint": "[create|list|connect|resolve|help]"
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "commands",
        "chat:write",
        "im:write",
        "users:read",
        "users:read.email"
      ]
    },
    "redirect_urls": [
      "https://api.itothread.com/slack/oauth/callback"
    ]
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://api.itothread.com/slack/events",
      "bot_events": [
        "app_mention",
        "app_uninstalled"
      ]
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false
  }
}
