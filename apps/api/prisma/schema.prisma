generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────── Auth & Users ────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String
  avatarUrl    String?
  bio          String?
  status       String?
  position     String?
  socialLinks  Json?
  role         SystemRole @default(USER)

  googleId String? @unique
  githubId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceMembers     WorkspaceMember[]
  teamMembers          TeamMember[]
  tasksCreated         Task[]         @relation("TaskCreator")
  tasksAssigned        Task[]         @relation("TaskAssignee")
  threadLinksFrom      ThreadLink[]   @relation("ThreadLinkSender")
  threadLinksTo        ThreadLink[]   @relation("ThreadLinkReceiver")
  notifications             Notification[]
  notificationPreferences   NotificationPreference[]
  refreshTokens             RefreshToken[]
  activities           Activity[]
  filesUploaded        File[]
  slackUsers           SlackUser[]
  slackLinkCodes       SlackLinkCode[]
  calendarIntegrations CalendarIntegration[]
  chatMessages         ChatMessage[]
  sharedSpacesCreated  SharedSpace[]
  taskGroupsCreated    TaskGroup[]
  taskGroupMembers     TaskGroupMember[]
  votes                Vote[]
  reminders            Reminder[]
  chatReadStatuses     ChatReadStatus[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ──────────────────── Workspace & Teams ────────────────────

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  avatarUrl   String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members                WorkspaceMember[]
  teams                  Team[]
  tasks                  Task[]
  invites                WorkspaceInvite[]
  activities             Activity[]
  slackWorkspaces        SlackWorkspace[]
  sharedSpaceParticipants SharedSpaceParticipant[]
  taskGroups             TaskGroup[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

model WorkspaceInvite {
  id          String        @id @default(cuid())
  workspaceId String
  email       String
  token       String        @unique @default(cuid())
  role        WorkspaceRole @default(MEMBER)
  expiresAt   DateTime
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
}

model Team {
  id          String   @id @default(cuid())
  name        String
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   TeamMember[]
  tasks     Task[]

  @@index([workspaceId])
}

model TeamMember {
  id       String   @id @default(cuid())
  userId   String
  teamId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
}

enum TeamRole {
  LEAD
  MEMBER
}

enum SystemRole {
  USER
  ADMIN
}

// ──────────────────── Task & Thread System ────────────────────

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(OPEN)
  priority    Priority   @default(MEDIUM)
  type        TaskType   @default(STANDARD)
  voteConfig  Json?
  dueDate     DateTime?

  creatorId     String
  assigneeId    String
  workspaceId   String
  teamId        String?
  sharedSpaceId String?
  taskGroupId   String?

  order       Int        @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  creator     User         @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee    User         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team        Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  sharedSpace SharedSpace? @relation(fields: [sharedSpaceId], references: [id], onDelete: SetNull)
  taskGroup   TaskGroup?   @relation(fields: [taskGroupId], references: [id], onDelete: SetNull)

  lastPulledAt  DateTime?

  threadLinks    ThreadLink[]
  votes          Vote[]
  files          File[]
  chatMessages   ChatMessage[]
  reminders      Reminder[]
  chatReadStatuses ChatReadStatus[]

  @@index([assigneeId])
  @@index([creatorId])
  @@index([workspaceId])
  @@index([teamId])
  @@index([sharedSpaceId])
  @@index([taskGroupId])
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELLED
}

enum Priority {
  URGENT
  HIGH
  MEDIUM
  LOW
}

enum TaskType {
  STANDARD
  VOTE
}

model Vote {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  choice    String
  comment   String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@index([taskId])
}

model ThreadLink {
  id         String           @id @default(cuid())
  taskId     String
  fromUserId String
  toUserId   String?
  type       ThreadLinkType   @default(PERSON)
  blockerNote String?
  message    String?
  status     ThreadLinkStatus @default(PENDING)
  chainIndex Int
  groupId    String?

  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
  lastPulledAt DateTime?

  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fromUser User   @relation("ThreadLinkSender", fields: [fromUserId], references: [id])
  toUser   User?  @relation("ThreadLinkReceiver", fields: [toUserId], references: [id])
  files    File[]

  @@index([taskId, chainIndex])
  @@index([toUserId, status])
  @@index([fromUserId])
  @@index([groupId])
}

enum ThreadLinkType {
  PERSON
  BLOCKER
}

enum ThreadLinkStatus {
  PENDING
  COMPLETED
  FORWARDED
  CANCELLED
}

// ──────────────────── Notifications ────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

enum NotificationType {
  THREAD_RECEIVED
  THREAD_SNAPPED
  THREAD_COMPLETED
  THREAD_DECLINED
  WORKSPACE_INVITE
  TASK_ASSIGNED
  TASK_COMPLETED
  SHARED_SPACE_INVITE
  CHAT_MESSAGE
  VOTE_COMPLETE
  THREAD_PULLED
  TASK_REMINDER
}

model NotificationPreference {
  id              String           @id @default(cuid())
  userId          String
  type            NotificationType
  inApp           Boolean          @default(true)
  email           Boolean          @default(false)
  slack           Boolean          @default(false)
  slackWebhookUrl String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

// ──────────────────── Activity Log ────────────────────

model Activity {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([entityType, entityId])
}

// ──────────────────── Files ────────────────────

model File {
  id           String  @id @default(cuid())
  filename     String
  url          String
  size         Int
  mimeType     String
  uploaderId   String
  taskId       String?
  threadLinkId String?

  chatMessageId String?

  createdAt DateTime @default(now())

  uploader    User         @relation(fields: [uploaderId], references: [id])
  task        Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  threadLink  ThreadLink?  @relation(fields: [threadLinkId], references: [id], onDelete: SetNull)
  chatMessage ChatMessage? @relation("ChatMessageFiles", fields: [chatMessageId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([threadLinkId])
  @@index([chatMessageId])
}

// ──────────────────── Slack Integration ────────────────────

model SlackWorkspace {
  id            String      @id @default(cuid())
  slackTeamId   String      @unique
  slackTeamName String
  accessToken   String
  botUserId     String?
  scope         String?
  workspaceId   String
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  slackUsers    SlackUser[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([workspaceId])
}

model SlackUser {
  id               String         @id @default(cuid())
  slackUserId      String
  slackWorkspaceId String
  userId           String
  slackChannelId   String?
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  slackWorkspace   SlackWorkspace @relation(fields: [slackWorkspaceId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())

  @@unique([slackUserId, slackWorkspaceId])
  @@index([userId])
}

model SlackLinkCode {
  id          String    @id @default(cuid())
  code        String    @unique
  userId      String
  workspaceId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// ──────────────────── Chat Messages ────────────────────

model ChatMessage {
  id         String   @id @default(cuid())
  content    String
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User     @relation(fields: [senderId], references: [id])
  parentId   String?
  parent     ChatMessage?  @relation("ChatThread", fields: [parentId], references: [id], onDelete: SetNull)
  replies    ChatMessage[] @relation("ChatThread")
  replyCount Int           @default(0)
  files      File[]        @relation("ChatMessageFiles")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([taskId, createdAt])
  @@index([senderId])
  @@index([parentId])
}

// ──────────────────── Shared Spaces (Cross-Workspace Collaboration) ────────────────────

model SharedSpace {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participants SharedSpaceParticipant[]
  tasks        Task[]
  invites      SharedSpaceInvite[]
  taskGroups   TaskGroup[]

  @@index([createdById])
}

model SharedSpaceParticipant {
  id            String          @id @default(cuid())
  sharedSpaceId String
  sharedSpace   SharedSpace     @relation(fields: [sharedSpaceId], references: [id], onDelete: Cascade)
  workspaceId   String
  workspace     Workspace       @relation(fields: [workspaceId], references: [id])
  role          SharedSpaceRole @default(MEMBER)
  joinedAt      DateTime        @default(now())

  @@unique([sharedSpaceId, workspaceId])
  @@index([workspaceId])
}

enum SharedSpaceRole {
  OWNER
  ADMIN
  MEMBER
}

model SharedSpaceInvite {
  id            String   @id @default(cuid())
  sharedSpaceId String
  sharedSpace   SharedSpace @relation(fields: [sharedSpaceId], references: [id], onDelete: Cascade)
  workspaceSlug String
  token         String   @unique @default(cuid())
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([sharedSpaceId])
  @@index([workspaceSlug])
}

// ──────────────────── Calendar Integration ────────────────────

model CalendarIntegration {
  id           String  @id @default(cuid())
  userId       String
  provider     String  // 'google' | 'outlook'
  accessToken  String
  refreshToken String
  calendarIds  String[]  @default([])
  syncEnabled  Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

// ──────────────────── Task Groups ────────────────────

model TaskGroup {
  id            String   @id @default(cuid())
  name          String
  description   String?
  workspaceId   String?
  sharedSpaceId String?
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sharedSpace SharedSpace? @relation(fields: [sharedSpaceId], references: [id], onDelete: Cascade)
  createdBy   User         @relation(fields: [createdById], references: [id])
  members     TaskGroupMember[]
  tasks       Task[]

  @@index([workspaceId])
  @@index([sharedSpaceId])
}

model TaskGroupMember {
  id          String   @id @default(cuid())
  taskGroupId String
  userId      String
  joinedAt    DateTime @default(now())

  taskGroup TaskGroup @relation(fields: [taskGroupId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskGroupId, userId])
  @@index([taskGroupId])
}

// ──────────────────── Reminders ────────────────────

model Reminder {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  remindAt  DateTime
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([remindAt, sent])
  @@index([userId])
}

// ──────────────────── Chat Read Status ────────────────────

model ChatReadStatus {
  id         String   @id @default(cuid())
  taskId     String
  userId     String
  lastReadAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
}
