# GitHub OAuth (optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="http://localhost:3011/auth/github/callback"

# App
API_PORT=3011
FRONTEND_URL="http://localhost:3010"

# Email — Resend (optional, invite emails skipped if not set)
RESEND_API_KEY=""
RESEND_FROM="ito <noreply@yourdomain.com>"
