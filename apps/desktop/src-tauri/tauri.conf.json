{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ito",
  "version": "0.6.3",
  "identifier": "com.ito.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3010",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "ito",
        "width": 1280,
        "height": 860,
        "minWidth": 640,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["ito"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
